{
  "name": "template_spa",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "cypress": "cypress open",
    "cypress:run": "cypress run",
    "api": "im down && im up evaluator-api",
    "service": "im down && im up evaluator && npm run open",
    "container": "docker build --build-arg GITHUB_TOKEN=\"${GITHUB_TOKEN:-${NODE_AUTH_TOKEN}}\" -t ghcr.io/agile-crafts-people/impact_evaluator_spa:latest .",
    "push": "docker push ghcr.io/agile-crafts-people/impact_evaluator_spa:latest",
    "open": "open -a 'Google Chrome' 'http://localhost:9097' || google-chrome 'http://localhost:9097' || exg-open 'localhost:9097'",
    "build-publish": "npm install --include=dev && npm run container && npm run push",
    "build-package": "npm install --include=dev && npm run container",
    "publish-package": "npm run push",
    "delete-package": "gh api -X DELETE /orgs/agile-crafts-people/packages/container/impact_evaluator_spa"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@agile-crafts-people/impact_spa_utils": "github:agile-crafts-people/impact_spa_utils#main",
    "@tanstack/vue-query": "^5.59.0",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vuetify": "^3.11.3"
  },
  "devDependencies": {
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^3.0.5",
    "@vitest/ui": "^3.0.5",
    "@vue/test-utils": "^2.4.6",
    "cypress": "^15.8.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.9.2",
    "vite": "^7.2.0",
    "vitest": "^3.0.5",
    "vue-tsc": "^2.2.0"
  },
  "overrides": {
    "glob": "^13.0.6",
    "qs": "^6.14.1"
  }
}